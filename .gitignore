# Quarto
/.quarto/
/_site/
/_book/
/_freeze/

# Per-machine Claude Code settings
.claude/settings.local.json

# HTML / listing leakage into the source tree (the only place they
# legitimately exist is _site/, which is already ignored above)
/index.html
/site_libs/
/chapters/**/*.html
/updates/*.html
/updates/*-listing.json
/updates/WU-*_files/
/updates/WU-*/index.html
/updates/WU-*/index-slides.html
/updates/WU-*/index_files/
/initiatives/**/*.html
/initiatives/**/*_files/

# LaTeX / PDF render byproducts
/*.tex
/index_files/
/*.log
/*.aux
/*.fdb_latexmk
/*.fls
/*.synctex.gz
/*.toc

# Generated assets (regenerated from CAD sources by build_cad.py
# and from index.qmd by build_gantt.py)
assets/models/*.glb
assets/figures/*.png
# Per-WU Gantt snapshots now live in updates/WU-*/media/gantt.png and are
# intentionally tracked — they freeze once the WU's date is in the past.

# Listing manifests (regenerated from .qmd front matter by build_listings.py)
updates/listing.yml
# Generated markdown-table partials for the initiatives tree (included via
# {{< include _listing.md >}}); regenerated by build_listings.py.
initiatives/**/_listing.md
initiatives/listing.yml
# Generated per-item file inventories (included via
# {{< include _files.md >}}); regenerated by build_file_trees.py.
initiatives/**/_files.md
# Generated change-history partials (included via
# {{< include _revisions.md >}}); regenerated by build_revisions.py.
initiatives/**/_revisions.md
updates/**/_revisions.md
chapters/**/_revisions*.md
# Generated dashboard board (included from index.qmd via
# {{< include _board.md >}}); regenerated by build_board.py.
/_board.md

# Per-week dispersal staging: raw dumps from OneDrive/thesis-inbox, routed
# into the repo by scripts/render/disperse.py + the /disperse skill.
# Kept as a local-only audit trail.
_inbox/
# Legacy per-week staging (superseded by _inbox/).
updates/*-update/

# Prototype/scratch output + per-clone Drive embed cache
scripts/tools/google-drive-embed/_proto_result.md
scripts/tools/google-drive-embed/_video_manifest.json
# OAuth secrets — NEVER commit
scripts/tools/google-drive-embed/client_secret.json
scripts/tools/google-drive-embed/token.json
**/client_secret*.json
**/token.json

# Python
__pycache__/
*.pyc
.venv/

# OS
.DS_Store
Thumbs.db

**/*.quarto_ipynb
