# Large media — tracked via git-lfs
*.mp4  filter=lfs diff=lfs merge=lfs -text
*.mov  filter=lfs diff=lfs merge=lfs -text
*.webm filter=lfs diff=lfs merge=lfs -text
*.mkv  filter=lfs diff=lfs merge=lfs -text

# CAD sources
*.step filter=lfs diff=lfs merge=lfs -text
*.stp  filter=lfs diff=lfs merge=lfs -text
*.f3d  filter=lfs diff=lfs merge=lfs -text
*.stl  filter=lfs diff=lfs merge=lfs -text
*.3mf  filter=lfs diff=lfs merge=lfs -text
*.sat  filter=lfs diff=lfs merge=lfs -text
*.3dm  filter=lfs diff=lfs merge=lfs -text
*.3dmbak filter=lfs diff=lfs merge=lfs -text

# Documents / datasheets imported from the archive (binary blobs)
*.pdf  filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
*.pptx filter=lfs diff=lfs merge=lfs -text
*.mht  filter=lfs diff=lfs merge=lfs -text

# Raster images (experiment photos, extracted deck screenshots)
*.png  filter=lfs diff=lfs merge=lfs -text
*.jpg  filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text

# Normalize text files
*.qmd text eol=lf
*.md  text eol=lf
*.yml text eol=lf
